{
  "info": {
    "name": "Dime Droppers — FanHub",
    "description": "Complete FanHub flow: manual school create (with logo) → ICS preview (generic + 4 platforms) → import feeds into a school (multi-feed, dedup on read) → fetch/list/delete. Auth: shared x-fanhub-key header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "fanhubKey", "value": "REPLACE_WITH_FANHUB_API_KEY", "type": "string" },
    { "key": "schoolId", "value": "", "type": "string" },
    { "key": "gameChangerIcs", "value": "https://gamechanger.com/team/tlam/feed.ics", "type": "string" },
    { "key": "teamSnapIcs", "value": "https://teamsnap.com/team/tlam/feed.ics", "type": "string" },
    { "key": "sportsEngineIcs", "value": "https://sportsengine.com/team/tlam/feed.ics", "type": "string" },
    { "key": "leagueAppsIcs", "value": "https://leagueapps.com/team/tlam/feed.ics", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Create School (Setup Team — Step 1, with logo)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('201 Created', () => pm.response.code === 201);",
              "const body = pm.response.json();",
              "const school = body.data && body.data[0] && body.data[0].school;",
              "pm.expect(school && school.id, 'school.id present').to.be.ok;",
              "pm.collectionVariables.set('schoolId', school.id);",
              "console.log('Saved schoolId =', school.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "x-fanhub-key", "value": "{{fanhubKey}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "logo", "type": "file", "src": [], "description": "Optional. PNG/JPG/WEBP/SVG, <=2MB, raster must be >=512x512" },
            { "key": "name", "value": "Twin Lakes Academy Middle School", "type": "text" },
            { "key": "teamName", "value": "TLAM", "type": "text" },
            { "key": "level", "value": "High School", "type": "text" },
            { "key": "sportsType", "value": "basketball", "type": "text" },
            { "key": "address", "value": "Fort Lauderdale, FL", "type": "text" },
            { "key": "league", "value": "Eastern Lakes Conference", "type": "text" },
            { "key": "primaryAudience", "value": "Students, Parents, Families", "type": "text" },
            { "key": "description", "value": "The Official fan hub for Twin Lakes Basketball team. Live scores, tickets, team updates and more!", "type": "text" },
            { "key": "contactName", "value": "John Doe", "type": "text" },
            { "key": "contactPhone", "value": "(555)123-4567", "type": "text" },
            { "key": "contactEmail", "value": "johndoe@tlam.com", "type": "text" },
            { "key": "website", "value": "https://www.tlam.com", "type": "text" },
            { "key": "colors", "value": "#000000", "type": "text" },
            { "key": "secondaryColor", "value": "#000000", "type": "text" },
            { "key": "accentColor", "value": "#231F20", "type": "text" }
          ]
        },
        "url": { "raw": "{{baseUrl}}/fanhub/schools", "host": ["{{baseUrl}}"], "path": ["fanhub", "schools"] },
        "description": "Manual create. Accepts multipart (with optional 'logo' file) or plain JSON. Captures schoolId into a collection variable for later requests."
      }
    },
    {
      "name": "1b. Create School (JSON only — no logo)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Twin Lakes Academy Middle School\",\n  \"teamName\": \"TLAM\",\n  \"level\": \"High School\",\n  \"sportsType\": \"basketball\",\n  \"address\": \"Fort Lauderdale, FL\",\n  \"league\": \"Eastern Lakes Conference\",\n  \"primaryAudience\": \"Students, Parents, Families\",\n  \"description\": \"The Official fan hub for Twin Lakes Basketball team.\",\n  \"contactName\": \"John Doe\",\n  \"contactPhone\": \"(555)123-4567\",\n  \"contactEmail\": \"johndoe@tlam.com\",\n  \"website\": \"https://www.tlam.com\",\n  \"colors\": \"#000000\",\n  \"secondaryColor\": \"#000000\",\n  \"accentColor\": \"#231F20\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/fanhub/schools", "host": ["{{baseUrl}}"], "path": ["fanhub", "schools"] },
        "description": "Same endpoint, JSON variant (no logo)."
      }
    },
    {
      "name": "2. ICS Preview — Generic (no DB write)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"{{gameChangerIcs}}\",\n  \"timeMin\": \"2026-06-01\",\n  \"timeMax\": \"2026-08-31\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/fanhub/ics/preview", "host": ["{{baseUrl}}"], "path": ["fanhub", "ics", "preview"] },
        "description": "Stateless fetch+parse. Accepts http(s):// or webcal://. timeMin/timeMax optional."
      }
    },
    {
      "name": "3. ICS Preview — GameChanger",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"url\": \"{{gameChangerIcs}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/fanhub/ics/gamechanger", "host": ["{{baseUrl}}"], "path": ["fanhub", "ics", "gamechanger"] },
        "description": "Platform-labeled preview. Response echoes platform: 'GameChanger'."
      }
    },
    {
      "name": "4. ICS Preview — TeamSnap",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"url\": \"{{teamSnapIcs}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/fanhub/ics/teamsnap", "host": ["{{baseUrl}}"], "path": ["fanhub", "ics", "teamsnap"] }
      }
    },
    {
      "name": "5. ICS Preview — SportsEngine",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"url\": \"{{sportsEngineIcs}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/fanhub/ics/sportsengine", "host": ["{{baseUrl}}"], "path": ["fanhub", "ics", "sportsengine"] }
      }
    },
    {
      "name": "6. ICS Preview — LeagueApps",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"url\": \"{{leagueAppsIcs}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/fanhub/ics/leagueapps", "host": ["{{baseUrl}}"], "path": ["fanhub", "ics", "leagueapps"] }
      }
    },
    {
      "name": "7. Import ICS into School — Feed A (GameChanger)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"url\": \"{{gameChangerIcs}}\",\n  \"platform\": \"GameChanger\"\n}" },
        "url": { "raw": "{{baseUrl}}/fanhub/schools/{{schoolId}}/import-ics", "host": ["{{baseUrl}}"], "path": ["fanhub", "schools", "{{schoolId}}", "import-ics"] },
        "description": "Persists this feed to the school. Per-source replace: re-running won't duplicate. 'platform' optional (auto-inferred from host if omitted)."
      }
    },
    {
      "name": "8. Import ICS into School — Feed B (TeamSnap, coexists)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"url\": \"{{teamSnapIcs}}\",\n  \"platform\": \"TeamSnap\"\n}" },
        "url": { "raw": "{{baseUrl}}/fanhub/schools/{{schoolId}}/import-ics", "host": ["{{baseUrl}}"], "path": ["fanhub", "schools", "{{schoolId}}", "import-ics"] },
        "description": "Second feed — does NOT wipe Feed A. Both coexist (tagged by sourceUrl)."
      }
    },
    {
      "name": "9. Get School by ID (schedule deduped on read)",
      "request": {
        "method": "GET",
        "header": [{ "key": "x-fanhub-key", "value": "{{fanhubKey}}" }],
        "url": { "raw": "{{baseUrl}}/fanhub/schools/{{schoolId}}", "host": ["{{baseUrl}}"], "path": ["fanhub", "schools", "{{schoolId}}"] },
        "description": "Returns school + full schedule. Cross-feed duplicates (same start time + venue) collapsed for display; raw rows remain in DB."
      }
    },
    {
      "name": "10. List Schools (paginated + filters)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-fanhub-key", "value": "{{fanhubKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"search\": \"\",\n  \"sportsType\": \"basketball\",\n  \"page\": 1,\n  \"limit\": 20\n}" },
        "url": { "raw": "{{baseUrl}}/fanhub/schools/list", "host": ["{{baseUrl}}"], "path": ["fanhub", "schools", "list"] },
        "description": "sportsType accepts a string, comma-separated string, or array."
      }
    },
    {
      "name": "11. Scrape from file (alternative create — Gemini)",
      "request": {
        "method": "POST",
        "header": [{ "key": "x-fanhub-key", "value": "{{fanhubKey}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": [], "description": "PDF or image of a schedule" },
            { "key": "gofanSchoolPage", "value": "", "type": "text", "description": "Optional URL" },
            { "key": "nfhsNetworkLink", "value": "", "type": "text", "description": "Optional URL" }
          ]
        },
        "url": { "raw": "{{baseUrl}}/fanhub/scrape", "host": ["{{baseUrl}}"], "path": ["fanhub", "scrape"] },
        "description": "Existing endpoint — extracts school + schedule from an uploaded document via Gemini."
      }
    },
    {
      "name": "12. Delete School (+ schedule)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "x-fanhub-key", "value": "{{fanhubKey}}" }],
        "url": { "raw": "{{baseUrl}}/fanhub/schools/{{schoolId}}", "host": ["{{baseUrl}}"], "path": ["fanhub", "schools", "{{schoolId}}"] },
        "description": "Cascades to SchoolScheduleEvent + best-effort S3 logo cleanup."
      }
    }
  ]
}
